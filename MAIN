local HttpService = game:GetService("HttpService")

local base = "https://raw.githubusercontent.com/SEU_USER/BxScript/main/"

local function loadModule(name)
	local code = game:HttpGet(base.."modules/"..name..".lua")
	return loadstring(code)()
end

local UI = loadModule("ui")
local Movement = loadModule("movement")

UI:Init()

UI:AddToggle("Fly", function(state)
	Movement:Fly(state)
end)

UI:AddSlider("Speed", 16, 100, function(value)
	Movement:SetSpeed(value)
end)

UI:AddSlider("Jump", 50, 200, function(value)
	Movement:SetJump(value)
end)
